  m_Name: "\u5BF9\u767D_\u573A\u666F5_\u7ED3\u5C3E"
  m_EditorClassIdentifier: 
  dialogueId: dialog.sample
  lines:
  - speakerName: "\u4ED6"
    content: "\u4F60\u6765\u4E86\u3002\u6211\u8FD8\u4EE5\u4E3A\u2026\u2026\u4F60\u4E0D\u6765\u4E86\u5462\u3002"
    eventKey: 
    portrait: {fileID: 21300000, guid: 8f6662e7a91a6324891c77bb2a088bf2, type: 3}
  - speakerName: "\u4E3B\u89D2"
    content: "\u600E\u4E48\u4F1A\u3002\u7ED9\u4F60\u7684\u6C7D\u6C34\u3002\u653E\u5B66\u2026\u2026\u8FD8\u53BB\u82B1\u7530\u90A3\u8FB9\u5427\uFF1F"
    eventKey: 
    portrait: {fileID: 21300000, guid: 341e14244c862f944af413b391a3e609, type: 3}
  - speakerName: "\u4ED6"
    content: "\u55EF\u3002\u53BB\u770B\u770B\u6211\u4EEC\u79CD\u7684\u82B1\u3002"
    eventKey: 
    portrait: {fileID: 21300000, guid: 8f6662e7a91a6324891c77bb2a088bf2, type: 3}
  - speakerName: "\u4E3B\u89D2"
    content: "\u884C\uFF0C\u51C6\u5907\u56DE\u53BB\u4E0A\u8BFE\u5427\uFF0C\u653E\u5B66\u540E\u4E00\u8D77\u8FC7\u53BB\u3002"
    eventKey: 
    portrait: {fileID: 21300000, guid: 341e14244c862f944af413b391a3e609, type: 3}
